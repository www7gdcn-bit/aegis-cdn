# deploy/.env.example — Phase 1 Step 3
#
# 用法:
#   cp deploy/.env.example deploy/.env
#   编辑 deploy/.env 把所有 ChangeMe 改成强密码
#   docker compose -f deploy/docker-compose.dev.yml --env-file deploy/.env up -d --build
#
# 安全:
#   .env 已在仓库根 .gitignore(*.env)被忽略,密码不会进库。
#   生产部署不要用本文件 — 走 secret manager / vault。

# ─────────────────────────────────────────
# MySQL(GoEdge 业务库)
# ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeMe_mysql_root_pw
MYSQL_DATABASE=db_edge
MYSQL_USER=edge
MYSQL_PASSWORD=ChangeMe_mysql_pw
MYSQL_PORT=3306

# ─────────────────────────────────────────
# Redis(GoEdge + SaaS 共享)
# ─────────────────────────────────────────
REDIS_PASSWORD=ChangeMe_redis_pw
REDIS_PORT=6379

# ─────────────────────────────────────────
# PostgreSQL(saas-svc 占位,Phase 2 启用)
# ─────────────────────────────────────────
POSTGRES_DB=aegis_saas
POSTGRES_USER=aegis
POSTGRES_PASSWORD=ChangeMe_pg_pw
POSTGRES_PORT=5432

# ─────────────────────────────────────────
# EdgeAPI(GoEdge 控制面)
#   EDGE_API_HOST = EdgeNode 连 EdgeAPI 用的主机名,
#     dev = 容器名 "edgeapi";生产 = api.example.com
#   EDGE_API_PORT = RPC 端口
# ─────────────────────────────────────────
EDGE_API_PROTOCOL=http
EDGE_API_HOST=edgeapi
EDGE_API_PORT=8003
EDGE_API_REST_PORT=8004

# ─────────────────────────────────────────
# EdgeNode(边缘节点)
#   首次启动前必须填 CLUSTER_ID + CLUSTER_SECRET,
#   通过 EdgeAPI 创建第一个集群后获得。
#   详见 deploy/README.md 「首次启动 5 步」步骤 3。
# ─────────────────────────────────────────
AEGIS_EDGE_API_ENDPOINTS=http://edgeapi:8003
EDGE_NODE_CLUSTER_ID=
EDGE_NODE_CLUSTER_SECRET=

# EdgeNode 对外端口(dev 映射到本机)
EDGE_NODE_HTTP_PORT=8080
EDGE_NODE_HTTPS_PORT=8443

# ─────────────────────────────────────────
# services/saas-svc(Phase 2 拆出的 SaaS 业务规则)
#   端口 4001;库 aegis_saas(D3 决策,与 apps/api 旧库物理隔离)。
#   docker-compose:profile=saas 才启;Phase 2 阶段建议宿主 npm run start:dev -w @aegis/saas-svc。
# ─────────────────────────────────────────
SAAS_SVC_PORT=4001

# JWT(签发权 = saas-svc;apps/api 与未来 bff-edge 共享 secret 仅验证)
# 至少 32 位;生产 saas-svc/main.ts assertProdSecrets() 拒弱秘钥启动
AEGIS_JWT_SECRET=ChangeMe_at_least_32_chars_random_secret_xxxxxxxxxxxxxxxx
AEGIS_JWT_EXPIRES_IN=7d

# 服务间互调密钥(/internal/* 端点必须带 X-Aegis-Internal-Token)
AEGIS_INTERNAL_SECRET=ChangeMe_at_least_32_chars_internal_secret_xxxxxxxxxxxxxx

# apps/api 调 saas-svc 的内部地址(QuotaClient 用)
# 宿主同机:http://localhost:4001;docker-compose 内:http://saas-svc:4001
SAAS_SVC_INTERNAL_URL=http://localhost:4001

# 开发态:saas-svc 未启时 apps/api QuotaClient fetch 失败放行(打 warn)。
# **生产环境必须留空或 false,否则配额体系形同虚设**
AEGIS_QUOTA_DEV_BYPASS=true

# ─────────────────────────────────────────
# services/bff-edge(Phase 3 EdgeAPI 桥接层)
#   端口 4002;saas-svc / apps/web 通过本服务调 GoEdge,不直连 gRPC。
#   docker-compose:profile=bff 才启;Phase 3 阶段建议宿主 npm run start:dev -w @aegis/bff-edge。
# ─────────────────────────────────────────
BFF_EDGE_PORT=4002

# EdgeAPI gRPC 地址 — bff-edge 用 admin token 调它创建/查询 GoEdge 资源
# 同机 dev:localhost:8003;docker-compose 内:edgeapi:8003
EDGE_API_GRPC_ADDR=localhost:8003

# SDK 模式:placeholder(默认,dev 离线友好)/ grpc(真接 EdgeAPI gRPC)
# 不设时:admin 凭证齐自动 grpc,否则 placeholder
EDGE_API_MODE=placeholder

# EdgeAPI admin node 凭证(由 docker-compose edgeapi 容器首次 setup 后,
# `docker compose exec edgeapi cat /app/configs/.admin-token.json` 取出后填这里)
EDGE_API_ADMIN_NODE_ID=
EDGE_API_ADMIN_NODE_SECRET=

# GoEdge 默认集群 id(数字,edgeNodeClusters.id)。
# bff-edge 创建 GoEdge user 时写到 edgeUsers.clusterId 字段;
# 后续 createBasicHTTPServer 在 admin 模式下会取 user.clusterId 覆盖 req.NodeClusterId,
# 若为 0 → 报 'invalid nodeClusterId'。setup 时 GoEdge 通常自动建 id=1 的默认集群。
EDGE_DEFAULT_CLUSTER_ID=1

# SDK gRPC 调试日志开关
# on  → SDK 在 console.error 打印每次 gRPC 实发 payload(createUser / createBasicHTTPServer 等)
#       bff-edge 进程内 docker logs 直接可见,诊断 GoEdge 校验错误必需
# off → 仅 RPC 失败时打印(默认行为),减少日志噪声
# 生产关闭,dev/E2E 推荐 on
EDGE_API_DEBUG=on

# saas-svc 调 bff-edge 的内部地址(EdgeProvisionService 用)
# 宿主同机:http://localhost:4002;docker-compose 内:http://bff-edge:4002
BFF_EDGE_INTERNAL_URL=http://localhost:4002

# ─────────────────────────────────────────
# Phase 3 Step 5 — DNS 验证
# ─────────────────────────────────────────
# 平台分配 CNAME 后缀;客户配 example.com CNAME → <hex>.<EDGE_CNAME_SUFFIX>
EDGE_CNAME_SUFFIX=aegiscdn.com
# DNS resolver(逗号分隔);默认走公共 DNS 提升可达性
DNS_RESOLVERS=8.8.8.8,1.1.1.1
# DomainVerificationCron 每 60s 跑一次,设 off 关闭
DOMAIN_VERIFY_CRON=on

# ─────────────────────────────────────────
# Phase 3 Step 6 — SSL/ACME 自动签发
# ─────────────────────────────────────────
# 平台运营在 GoEdge 注册的共用 ACME User id(LE 或 ZeroSSL,绑定 ACMEProvider)
# 留空时 saas-svc 不会自动签发(SslAutoIssueCron 跳过)
EDGE_DEFAULT_ACME_USER_ID=
# 证书剩余有效期 ≤ N 天时自动续期(LE 默认 90 天,30 天续期工业惯例)
SSL_RENEW_WITHIN_DAYS=30
# SslAutoIssueCron 每 5min 跑,设 off 关闭
SSL_AUTO_CRON=on

# ─────────────────────────────────────────
# Phase 3 Step 7 — 全局封禁同步
# ─────────────────────────────────────────
# 平台运营在 GoEdge 创建的共享 IPList id(type=black, isGlobal=true)
# 留空时 saas-svc 创建 type=ip|cidr 封禁会标 syncStatus=failed(syncError 提示去配)
# domain/tenant 维度封禁不需要此 env(syncStatus=skipped)
EDGE_GLOBAL_BLOCK_LIST_ID=

# NestJS 控制面配置
DATABASE_URL="postgresql://aegis:aegis_pass@localhost:5432/aegis?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev_jwt_secret_change_me_at_least_32_chars_xx"
JWT_EXPIRES_IN="7d"
PORT=4000
# 分配给客户的接入 CNAME 后缀域(客户把自己域名 CNAME 到 <token>.该后缀)
CNAME_SUFFIX="aegis-cdn.net"
CORS_ORIGINS="http://localhost:3000"
# 攻击可视化数据源(留空则后台显示样本数据)
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_DB="aegis"

# 支付回调/跳转用的公开地址(生产填真实域名)
PUBLIC_API_URL="http://localhost:4000/api/v1"   # 网关异步回调:<此地址>/payments/callback/<gateway>
PUBLIC_WEB_URL="http://localhost:3000"          # 支付完成跳回前端
# 支付网关商户参数不在 .env 配置,全部在「管理后台 → 支付配置」填写(后台热更新)

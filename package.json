{
  "name": "aegis-cdn",
  "private": true,
  "version": "0.1.0",
  "description": "AegisCDN — 商用级高防 CDN / DDoS 防护 SaaS 平台",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @aegis/web",

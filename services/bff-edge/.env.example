# services/bff-edge/.env.example — Phase 3 Step 1
#
# bff-edge 自己不持有库,通过 EdgeAPI gRPC 操作 GoEdge,
# 通过 saas-svc /internal/quota/check 询问配额。

# 端口
PORT=4002

# JWT(与 saas-svc / apps/api 共享 secret,仅验证)
JWT_SECRET="dev_jwt_secret_change_me_at_least_32_chars_xx"

# 服务间互调密钥(本服务 /internal/* 入口校验 + 调 saas-svc 时带的 token,与 saas-svc 共享)
AEGIS_INTERNAL_SECRET="dev_internal_secret_change_me_at_least_32_chars_xx"

# saas-svc /internal/* 地址(本服务调它做配额/同步)
SAAS_SVC_INTERNAL_URL=http://localhost:4001

# EdgeAPI gRPC 地址
EDGE_API_GRPC_ADDR=localhost:8003

# SDK 模式:
#   placeholder(默认)— 所有 SDK 方法 throw NotImplementedError,bff-edge 端点返回
#                      502 EDGE_API_NOT_READY。无需真实 EdgeAPI,dev 友好
#   grpc           — 真接 GoEdge gRPC,需 EDGE_API_ADMIN_NODE_ID + SECRET
# 不设此变量时:若 adminNodeId + secret 齐自动选 grpc,否则 placeholder
EDGE_API_MODE=placeholder

# EdgeAPI admin node 凭证(setup 阶段返回的 adminNodeId/adminNodeSecret)
# 从 `docker compose exec edgeapi cat /app/configs/.admin-token.json` 取
EDGE_API_ADMIN_NODE_ID=
EDGE_API_ADMIN_NODE_SECRET=

# CORS
CORS_ORIGINS="http://localhost:3000"

# Node env
NODE_ENV=development

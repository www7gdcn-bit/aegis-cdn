// services/saas-svc/prisma/schema.prisma
// Phase 2 Step B — SaaS 业务表(从 apps/api/prisma/schema.prisma 复制 + 加 edgeUserId)
//
// 本 schema 与 apps/api 物理隔离(D3 决策):
//   - 库名:aegis_saas(apps/api 残留库另叫 aegis_cdn)
//   - 不持有 Domain/Origin/CC/WAF/ACL/RateRule(留 apps/api,Phase 3 起整体由 bff-edge 接管)
//   - Tenant.edgeUserId 是与 GoEdge MySQL users.id 的软关联(Phase 3 由 bff-edge 写入)
//
// 关联: docs/15 §3 架构图、docs/17 §1.1 saas-svc 数据归属。

generator client {
  provider = "prisma-client-js"
  // 独立 output 避免与 apps/api 的 @prisma/client 在共享 node_modules 中互相覆盖
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================================================
// 租户 / 用户
// ========================================================================

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("active") // active | suspended
  kycStatus String   @default("none")   // none | pending | approved | rejected
  kycInfo   Json?    // 企业资料:营业执照号/法人/联系人/行业等

  // ── GoEdge user 关联(Phase 3 由 bff-edge 写入)──
  // 一个 Tenant ↔ GoEdge 一个 user(承载计费/配额);Tenant 下可有多 SaaS User
  edgeUserId       Int?      @unique
  edgeUserSyncedAt DateTime?

  users        User[]
  subscription Subscription?
  orders       Order[]
  edgeProvision PendingEdgeProvision?
  domains      SaasDomain[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 3 Step 4 — SaaS 域名 onboarding 表(saas 侧权威源)。
//
// 一行 = 客户接入的一个域名。GoEdge 侧对应的 server 通过 edgeDomainId 关联。
//
// 状态机:
//   pending      初建,正在调 bff-edge 写 GoEdge,可重试
//   dns_pending  GoEdge 创建成功,等用户在自己的 DNS 配 CNAME → cnameTarget
//   active       CNAME 已生效,流量通(Step 4 阶段简化:管理员手动或定时 DNS 检测后置位)
//   paused       用户主动暂停 / 平台暂停(欠费等)
//   failed       GoEdge 创建失败永久态(需运营介入或删除重试)
//
// sslStatus 与 verificationStatus 留字段不深入实现(Step 6+ SSL/ACME 才动)。
model SaasDomain {
  id                  Int       @id @default(autoincrement())
  tenantId            Int
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 用户接入的域名(主域名);唯一,跨租户也唯一(避免不同租户接同一域名)
  domain              String    @unique

  // GoEdge ServerService 返回的 serverId;成功后写入
  edgeDomainId        Int?      @unique

  // 平台分配的 CNAME 目标 — 客户应把 domain 的 CNAME 解析到这里
  // 格式:<8 位 hex>.<EDGE_CNAME_SUFFIX>(默认 aegiscdn.com)
  cnameTarget         String    @unique

  status              String    @default("pending")   // pending|dns_pending|active|paused|failed
  sslStatus           String    @default("none")      // none|pending|issued|failed|expired|renewing
  verificationStatus  String    @default("pending")   // pending|verified|failed

  originHost          String?   // 源站 host:port(用户填);Step 4 字段保留,GoEdge 接受协议字符串

  lastError           String?
  lastErrorAt         DateTime?
  edgeSyncedAt        DateTime? // 最近一次成功同步到 GoEdge 的时间

  // Phase 3 Step 5 — DNS 验证字段
  verifiedAt          DateTime? // CNAME 解析首次匹配的时间(status 切到 active 那一刻)
  lastVerifyAt        DateTime? // 最近一次跑验证(无论结果)
  lastVerifyError     String?   // 最近一次错误(DNS 查询失败 / 配置不匹配等);成功时清空

  // Phase 3 Step 6 — SSL/ACME 字段
  // 整套生命周期:none(初) → pending(任务下发中) → issued(成功) → expired/renewing/failed
  // sslStatus 已在上方 — 这里加配套数据
  acmeTaskId          Int?      // GoEdge ACMETask.id;runACMETask 后写
  sslCertId           Int?      @unique // GoEdge SSLCert.id;runACMETask 成功返
  sslIssuedAt         DateTime? // 首次签发成功时间
  sslExpiresAt        DateTime? // LE 默认 90 天;距到期 < 30 天触发续期
  sslRenewedAt        DateTime? // 上次续期时间(非首次)
  lastSslAttemptAt    DateTime? // 上次尝试 ACME(无论成功/失败)
  lastSslError        String?   // ACME 失败原因;成功时清空

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([status, lastVerifyAt])    // dns 检测 cron 热路径
  @@index([status, sslStatus, sslExpiresAt])  // ssl auto-issue/renew cron 热路径
}

// Phase 3 Step 3:GoEdge user 同步状态机 + retry queue。
//
// 一个 Tenant 对应 0 或 1 条记录(@@unique tenantId):
//   - register 时 saas-svc.AuthService 异步 scheduleProvision() 创建 status=pending 一条
//   - cron 每 30s 扫 status in [pending, retrying] AND nextTryAt <= now,批量调 bff-edge
//   - 成功 → status=done,同时回写 Tenant.edgeUserId + edgeUserSyncedAt
//   - 瞬时失败(grpc UNAVAILABLE/DEADLINE/未就绪) → status=retrying,attempts++,
//     指数退避 nextTryAt
//   - 永久失败(ALREADY_EXISTS/INVALID_ARGUMENT/或超过 maxAttempts) → status=failed,
//     不再自动重试;运营可走 admin retry 端点手动重置
//
// Tenant.edgeUserId 真正写入只发生在本表 status=done 那次 transaction,二者一致性强保证。
model PendingEdgeProvision {
  id          Int       @id @default(autoincrement())
  tenantId    Int       @unique
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status      String    @default("pending")  // pending | retrying | done | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(8)          // 超过即 status=failed(运营介入)
  lastError   String?
  lastErrorAt DateTime?
  nextTryAt   DateTime  @default(now())
  resolvedAt  DateTime?                      // done / failed 终态时间戳
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextTryAt])              // cron 扫描热路径
}

model User {
  id           Int       @id @default(autoincrement())
  tenantId     Int?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("user") // user | operator | admin
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// 全局封禁(平台管理员手动:违规域名 / 恶意 IP)
// D2 决策:留 saas-svc;Phase 3 由 bff-edge 同步到 GoEdge ip_list
model GlobalBlock {
  id        Int       @id @default(autoincrement())
  type      String    // ip | domain
  value     String
  reason    String?
  createdBy Int?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([type, value])
}

// ========================================================================
// 套餐 / 订阅 / 订单
// ========================================================================

// 套餐(平台级)。金额用整数元,避免 Decimal/BigInt 序列化摩擦。
model Plan {
  id             Int            @id @default(autoincrement())
  code           String         @unique // starter | business | enterprise
  name           String
  tier           Int
  priceMonthly   Int            // 元/月
  priceYearly    Int            // 元/年
  protectionGbps Int            @default(0) // 防护容量承诺(G);0=定制
  trafficGb      Int            @default(0) // 月流量额度 GB;0=不限/定制
  domainLimit    Int            @default(1)
  features       Json           @default("{}") // {cc,waf,geo,bot,dedicated}
  isActive       Boolean        @default(true)
  isCustom       Boolean        @default(false)
  subscriptions  Subscription[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// 租户当前订阅(简化:每租户一份)
model Subscription {
  id                 Int      @id @default(autoincrement())
  tenantId           Int      @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             Int
  plan               Plan     @relation(fields: [planId], references: [id])
  status             String   @default("trialing") // trialing|active|past_due|canceled|expired
  cycle              String   @default("monthly")  // monthly|yearly
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id        Int       @id @default(autoincrement())
  orderNo   String    @unique
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String    // new | renew | upgrade
  planId    Int?
  cycle     String?
  amount    Int        // 应付金额(元)
  status    String     @default("pending") // pending | paid | canceled
  method    String?    // mock | wallet | stripe
  createdAt DateTime   @default(now())
  paidAt    DateTime?
}

// ========================================================================
// 支付系统(Payment Gateway Adapter Architecture)
// ========================================================================
// 所有支付参数后台可配置,勿写死;后期填商户信息即可启用对应网关。

model PaymentGateway {
  id           Int      @id @default(autoincrement())
  code         String   @unique // mock | alipay | wechat | qqpay | stripe | paypal | crypto
  name         String
  enabled      Boolean  @default(false)
  sandbox      Boolean  @default(true)
  config       Json     @default("{}") // merchantId/appId/apiKey/secret/publicKey... 后台填
  feeBps       Int      @default(0)    // 手续费,基点(100=1%)
  exchangeRate Float    @default(1)    // 相对结算币种汇率
  icon         String?
  sortOrder    Int      @default(100)
  currencies   String   @default("CNY") // 支持币种,逗号分隔
  ipWhitelist  String?                  // 回调 IP 白名单(逗号分隔;空=不限)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Payment {
  id            Int       @id @default(autoincrement())
  paymentNo     String    @unique
  tenantId      Int
  orderId       Int?      // 关联 Order(订阅订单)
  gatewayCode   String
  subject       String
  amount        Int       // 金额(元)
  fee           Int       @default(0)
  currency      String    @default("CNY")
  status        String    @default("pending") // pending|paid|failed|expired|refunded
  providerTxnId String?   // 第三方交易号
  clientIp      String?
  payUrl        String?
  expiresAt     DateTime?
  paidAt        DateTime?
  raw           Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
}

model PaymentLog {
  id        Int      @id @default(autoincrement())
  paymentNo String
  event     String   // create|callback|query|refund|simulate|error
  ip        String?
  payload   Json?
  result    String?
  createdAt DateTime @default(now())

  @@index([paymentNo])
}

model Refund {
  id               Int      @id @default(autoincrement())
  refundNo         String   @unique
  paymentNo        String
  amount           Int
  reason           String?
  status           String   @default("pending") // pending|done|failed
  providerRefundId String?
  createdAt        DateTime @default(now())
}

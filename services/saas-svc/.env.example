# services/saas-svc/.env.example — Phase 2

# 业务库(全新独立 aegis_saas,与 apps/api 旧库物理隔离)
DATABASE_URL="postgresql://aegis:ChangeMe_pg_pw@localhost:5432/aegis_saas?schema=public"

# Redis(logical db=1,与 GoEdge db=0 隔离)
REDIS_URL="redis://default:ChangeMe_redis_pw@localhost:6379/1"

# 端口
PORT=4001

# JWT(签发权在 saas-svc;apps/api 与未来 bff-edge 共享同一 secret 仅验证)
JWT_SECRET="dev_jwt_secret_change_me_at_least_32_chars_xx"
JWT_EXPIRES_IN="7d"

# 服务间互调密钥(/internal/* 端点必须带 X-Aegis-Internal-Token)
AEGIS_INTERNAL_SECRET="dev_internal_secret_change_me_at_least_32_chars_xx"

# CORS
CORS_ORIGINS="http://localhost:3000"

# Node env
NODE_ENV=development
